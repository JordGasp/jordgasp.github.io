---

---

<section id='contact' class='py-20 px-4'>
	<div class='max-w-2xl mx-auto'>
		<div class='text-center mb-12'>
			<h2
				class='text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-accent-green to-accent-purple bg-clip-text text-transparent py-2'
			>
				Get In Touch
			</h2>
			<p class='text-gray-400 text-lg'>
				Have a process that still requires a human? Let's talk.
			</p>
		</div>

		<div
			class='bg-dark-card border border-dark-border rounded-xl p-8 hover:border-accent-green/40 transition-all duration-300'
		>
			<form id='contact-form'>
				<input
					type='hidden'
					name='access_key'
					value='4c9f8d93-094b-4b39-a2a1-84fd683cd892'
				/>
				<input
					type='hidden'
					name='subject'
					value='[Portfolio] New message from contact form'
				/>
				<input
					type='hidden'
					name='message_source'
					value='PORTFOLIO_WEB3FORMS_JORDGASP'
				/>
				<input
					type='hidden'
					name='from_name'
					value='Portfolio Contact'
				/>
				<input
					type='checkbox'
					name='botcheck'
					class='hidden'
					style='display:none;'
				/>

				<div class='mb-6'>
					<label
						for='name'
						class='block text-sm font-medium text-gray-400 mb-2'
						>Name</label
					>
					<input
						type='text'
						id='name'
						name='name'
						required
						placeholder='Your name'
						class='w-full px-4 py-3 bg-dark-bg border border-dark-border rounded-lg text-dark-text placeholder-gray-600 focus:outline-none focus:border-accent-green/60 transition-colors duration-200 font-sans'
					/>
				</div>

				<div class='mb-6'>
					<label
						for='email'
						class='block text-sm font-medium text-gray-400 mb-2'
						>Email</label
					>
					<input
						type='email'
						id='email'
						name='email'
						required
						placeholder='your@email.com'
						class='w-full px-4 py-3 bg-dark-bg border border-dark-border rounded-lg text-dark-text placeholder-gray-600 focus:outline-none focus:border-accent-green/60 transition-colors duration-200 font-sans'
					/>
				</div>

				<div class='mb-8'>
					<label
						for='message'
						class='block text-sm font-medium text-gray-400 mb-2'
						>Message</label
					>
					<textarea
						id='message'
						name='message'
						required
						rows='5'
						placeholder='Describe your automation problem...'
						class='w-full px-4 py-3 bg-dark-bg border border-dark-border rounded-lg text-dark-text placeholder-gray-600 focus:outline-none focus:border-accent-green/60 transition-colors duration-200 font-sans resize-none'
					></textarea>
				</div>

				<div class='h-captcha mb-6' data-captcha='true'></div>

				<button
					type='submit'
					id='submit-btn'
					class='w-full px-8 py-3 bg-accent-green hover:bg-accent-green/80 text-dark-bg font-semibold rounded-lg transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-accent-green/50 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100'
				>
					Send Message
				</button>

				<div id='form-status' class='mt-4 text-center text-sm hidden'>
				</div>
			</form>
		</div>
	</div>
	<script is:inline src='https://web3forms.com/client/script.js' async defer
	></script>
</section>

<script>
	const form = document.getElementById("contact-form") as HTMLFormElement;
	const btn = document.getElementById("submit-btn") as HTMLButtonElement;
	const status = document.getElementById("form-status") as HTMLDivElement;

	form.addEventListener("submit", async (e) => {
		e.preventDefault();

		const hCaptcha = (
			form.querySelector(
				"textarea[name=h-captcha-response]",
			) as HTMLTextAreaElement
		)?.value;
		if (!hCaptcha) {
			status.textContent = "Please complete the captcha.";
			status.className = "mt-4 text-center text-sm text-red-400";
			status.classList.remove("hidden");
			return;
		}

		btn.disabled = true;
		btn.textContent = "Sending...";
		status.classList.add("hidden");

		const data = Object.fromEntries(new FormData(form));

		try {
			const res = await fetch("https://api.web3forms.com/submit", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(data),
			});

			const json = await res.json();

			if (json.success) {
				status.textContent = "Message sent. I'll get back to you soon.";
				status.className = "mt-4 text-center text-sm text-accent-green";
				form.reset();
			} else {
				throw new Error("Submission failed");
			}
		} catch {
			status.textContent =
				"Something went wrong. Try again or reach out directly.";
			status.className = "mt-4 text-center text-sm text-red-400";
		} finally {
			btn.disabled = false;
			btn.textContent = "Send Message";
			status.classList.remove("hidden");
		}
	});
</script>
