---

---

<section
	class='relative min-h-screen flex items-center justify-center px-4 overflow-hidden'
>
	<!-- Animated background -->
	<div class='absolute inset-0 opacity-20'>
		<div
			class='absolute top-1/4 left-1/4 w-96 h-96 bg-accent-green/20 rounded-full blur-3xl animate-pulse'
		>
		</div>
		<div
			class='absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-purple/20 rounded-full blur-3xl animate-pulse'
			style='animation-delay: 1s;'
		>
		</div>
	</div>

	<div class='relative z-10 max-w-4xl mx-auto text-center'>
		<!-- Name -->
		<h1
			class='text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-accent-green to-accent-purple bg-clip-text text-transparent py-2 fix-dark'
		>
			Jordan Gaspoz
		</h1>

		<!-- Title -->
		<h2
			class='text-2xl md:text-3xl font-semibold mb-4 text-dark-text fix-dark'
		>
			Backend & Automation Engineer
		</h2>

		<!-- Tagline -->
		<p class='text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto'>
			I was hired to do it by hand. I automated everything instead.
		</p>

		<!-- Tech Stack Preview -->
		<p class='text-base text-gray-500 mb-8 max-w-xl mx-auto italic'>
			5h of daily manual work → 15 min. Pipeline built from scratch,
			custom tooling invented on the spot, fully deployed.
		</p>

		<!-- Location & Status -->
		<div
			class='flex flex-wrap items-center justify-center gap-4 mb-12 text-sm text-gray-400'
		>
			<div class='flex items-center gap-2'>
				<svg class='w-4 h-4' fill='currentColor' viewBox='0 0 20 20'>
					<path
						fill-rule='evenodd'
						d='M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z'
						clip-rule='evenodd'></path>
				</svg>
				<span>UTC+1 (CET)</span>
			</div>
			<span class='text-gray-700'>•</span>
			<div class='flex items-center gap-2'>
				<span class='relative flex h-2 w-2'>
					<span
						class='animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75'
					></span>
					<span
						class='relative inline-flex rounded-full h-2 w-2 bg-accent-green'
					></span>
				</span>
				<span>Available worldwide for remote work</span>
			</div>
		</div>

		<!-- CTA Buttons -->
		<div class='flex flex-wrap items-center justify-center gap-4'>
			<a
				href='#projects'
				class='px-8 py-3 bg-accent-green
			hover:bg-accent-green/80 text-dark-bg font-semibold rounded-lg
			transition-all duration-300 hover:scale-105 hover:shadow-lg
			hover:shadow-accent-green/50 fix-dark'
			>
				View Projects
			</a>
			<a
				href='https://github.com/JordGasp'
				target='_blank'
				rel='noopener
		noreferrer'
				class='px-8 py-3 border border-gray-500
		hover:border-gray-300 text-gray-300 hover:text-white font-semibold
		rounded-lg transition-all duration-300 hover:scale-105 backdrop-blur-sm
		hover:bg-white/5'
			>
				GitHub Profile
			</a>
			<a
				href='/contact'
				class='px-8 py-3 border border-accent-purple/50
	hover:border-accent-purple text-accent-purple hover:text-white
	hover:bg-accent-purple/10 font-semibold rounded-lg transition-all
	duration-300 hover:scale-105 backdrop-blur-sm'
			>
				Contact
			</a>
		</div>
	</div>

	<!-- Scroll indicator — inside the section, after the content div, before </section> -->
	<div class='absolute bottom-8 left-1/2 -translate-x-1/2'>
		<div class='animate-bounce-slow flex flex-col items-center gap-1'>
			<span class='text-xs text-gray-600 tracking-widest uppercase'
				>Scroll</span
			>
			<svg
				class='w-5 h-5 text-gray-500'
				fill='none'
				stroke='currentColor'
				viewBox='0 0 24 24'
				stroke-width='2.5'
			>
				<path
					stroke-linecap='round'
					stroke-linejoin='round'
					d='M19 14l-7 7m0 0l-7-7m7 7V3'></path>
			</svg>
		</div>
	</div>

	<style>
		.fix-dark {
			forced-color-adjust: none !important;
		}

		@keyframes pulse {
			0%,
			100% {
				opacity: 0.2;
				transform: scale(1);
			}
			50% {
				opacity: 0.3;
				transform: scale(1.1);
			}
		}

		.animate-pulse {
			animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
		}
	</style>
</section>
