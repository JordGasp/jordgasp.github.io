---
interface Props {
  title: string;
  tagline: string;
  description: string;
  tech: string[];
  slug: string;
  github?: string;
}

const { title, tagline, description, tech, slug, github } = Astro.props;
const projectUrl = `/projects/${slug}`;
---

<article class="group relative bg-dark-card/80 backdrop-blur-sm border border-dark-border rounded-xl p-6 transition-all duration-300 hover:border-accent-green/60 hover:shadow-xl hover:shadow-accent-green/15 hover:-translate-y-1">
  <div class="absolute inset-0 bg-gradient-to-br from-accent-green/5 to-accent-purple/5 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

  <div class="relative z-10">
    <h3 class="text-2xl font-bold mb-2 text-dark-text group-hover:text-accent-green transition-colors duration-300">
      <a href={projectUrl} class="hover:underline decoration-accent-green/30">
        {title}
      </a>
    </h3>

    <p class="text-sm text-accent-purple font-mono mb-4">
      {tagline}
    </p>

    <p class="text-gray-400 mb-6 line-clamp-3">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {tech.slice(0, 4).map((t) => (
        <span class="px-3 py-1 text-xs font-mono bg-dark-bg border border-dark-border rounded-full text-gray-400">
          {t}
        </span>
      ))}
      {tech.length > 4 && (
        <span class="px-3 py-1 text-xs font-mono bg-dark-bg border border-dark-border rounded-full text-gray-400">
          +{tech.length - 4} more
        </span>
      )}
    </div>

<div class="flex items-center gap-4">
      <a
        href={projectUrl}
        class="inline-flex items-center gap-2 text-accent-green hover:text-accent-green/80 hover:underline decoration-2 underline-offset-4 font-semibold transition-all duration-300"
      >
        <span>View Details</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-auto mr-4 inline-flex items-center gap-2 text-gray-500 hover:text-accent-purple transition-colors duration-300"
          aria-label="View on GitHub"
        >
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>