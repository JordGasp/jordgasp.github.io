---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Jordan Gaspoz - Backend & Automation Engineer">
  <Hero />

  <!-- Projects Section -->
  <section id="projects" class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-accent-green to-accent-purple bg-clip-text text-transparent py-2">
          Featured Projects
        </h2>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Production-grade systems built with a focus on reliability, scalability, and automation
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {sortedProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            tagline={project.data.tagline}
            description={project.data.description}
            tech={project.data.tech}
            slug={project.slug}
            github={project.data.github}
          />
        ))}
      </div>
    </div>
  </section>

<!-- Core Expertise Section -->
  <section class="py-20 px-4 bg-dark-card/30">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-dark-text">
          Core Expertise
        </h2>
        <p class="text-gray-400">
          Skills and the tools that power them
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            area: 'Infrastructure & Orchestration',
            description: 'Containerised deployments, workflow automation, and cross-platform scripting for reliable, repeatable ops.',
            tools: ['Docker', 'n8n', 'Docker Compose', 'PowerShell'],
            color: 'accent-green',
          },
          {
            area: 'Backend Development',
            description: 'Lightweight API design, relational data modelling, and server-side automation pipelines.',
            tools: ['Python 3.11', 'Flask', 'SQLite'],
            color: 'accent-purple',
          },
          {
            area: 'AI & Integration',
            description: 'LLM-powered processing chains, Telegram platform integration, and transcription pipelines.',
            tools: ['Claude API', 'Telethon', 'faster-whisper'],
            color: 'accent-green',
          },
        ].map((expertise) => (
          <div class="bg-dark-card border border-dark-border rounded-xl p-6 hover:border-accent-green/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-green/5 group">
            <h3 class={`text-base font-semibold mb-2 text-${expertise.color} group-hover:opacity-100 transition-opacity`}>
              {expertise.area}
            </h3>
            <p class="text-gray-500 text-sm mb-5 leading-relaxed">
              {expertise.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {expertise.tools.map((tool) => (
                <span class="px-2.5 py-1 text-xs font-mono bg-dark-bg border border-dark-border rounded-md text-gray-400">
                  {tool}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
