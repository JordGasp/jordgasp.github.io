---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Footer from "../components/Footer.astro";

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title='Jordan Gaspoz - Backend & Automation Engineer'>
	<Hero />

	<!-- About Section -->
	<section class='py-16 px-4'>
		<div class='max-w-2xl mx-auto text-center'>
			<p class='text-gray-300 text-lg leading-relaxed'>
				I don't just write code. <br />I look at a <strong
					class='text-dark-text'>process</strong
				> and ask why it still requires a human. <br />When I was
				brought in to manually manage a Telegram content operation, I
				spent the first week understanding the system, then built a
				pipeline that made the <strong class='text-dark-text'
					>manual work obsolete.</strong
				>
				That's the instinct I bring to every backend or <strong
					class='text-dark-text'>automation problem.</strong
				>
			</p>
		</div>
	</section>

	<!-- Projects Section -->
	<section id='projects' class='py-20 px-4'>
		<div class='max-w-6xl mx-auto'>
			<!-- Section Header -->
			<div class='text-center mb-16'>
				<h2
					class='text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-accent-green to-accent-purple bg-clip-text text-transparent py-2'
				>
					Featured Projects
				</h2>
				<p class='text-gray-400 text-lg max-w-2xl mx-auto'>
					Real problems I was hired to do by hand but chose to
					automate instead
				</p>
			</div>

			<!-- Projects Grid -->
			<div class='grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-8'>
				{
					sortedProjects.map((project) => (
						<ProjectCard
							title={project.data.title}
							tagline={project.data.tagline}
							description={project.data.description}
							tech={project.data.tech}
							slug={project.slug}
							github={project.data.github}
						/>
					))
				}
			</div>
		</div>
		<!-- Post-projects CTA -->
		<div class='text-center mt-16'>
			<p class='text-gray-400 mb-6'>Interested in what you see?</p>
			<a
				href='/contact'
				class='inline-flex items-center gap-2 px-8 py-3 border border-accent-purple/50
        hover:border-accent-purple text-accent-purple hover:text-white
        hover:bg-accent-purple/10 font-semibold rounded-lg transition-all
        duration-300 hover:scale-105 backdrop-blur-sm'
			>
				Get in touch
				<svg
					class='w-4 h-4'
					fill='none'
					stroke='currentColor'
					viewBox='0 0 24 24'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						stroke-width='2'
						d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
				</svg>
			</a>
		</div>
	</section>

	<!-- Core Expertise Section -->
	<section class='py-20 px-4 bg-dark-card/30'>
		<div class='max-w-6xl mx-auto'>
			<div class='text-center mb-12'>
				<h2 class='text-3xl md:text-4xl font-bold mb-4 text-dark-text'>
					Core Expertise
				</h2>
				<p class='text-gray-400'>
					Skills and the tools that power them
				</p>
			</div>

			<div class='grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6'>
				{
					[
						{
							area: "Infrastructure & Orchestration",
							description:
								"Turned manual multi-hour ops into one-command deployments. If it runs more than once, it runs automatically.",
							tools: [
								"Docker",
								"n8n",
								"Docker Compose",
								"PowerShell",
							],
							color: "accent-green",
						},
						{
							area: "Backend Development",
							description:
								"Built the server layer that parsed custom HTML tags, reconstructed Telegram premium emoji objects, and routed structured Claude outputs to the right channels.",
							tools: ["Python 3.11", "Flask", "SQLite"],
							color: "accent-purple",
						},
						{
							area: "AI & Integration",
							description:
								"Reduced a 5-hour daily content workflow to 15 minutes — Whisper transcription, Claude generation, Telethon delivery, fully orchestrated.",
							tools: ["Claude API", "Telethon", "faster-whisper"],
							color: "accent-green",
						},
					].map((expertise) => (
						<div class='bg-dark-card border border-dark-border rounded-xl p-6 hover:border-accent-green/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-green/5 group flex flex-col h-full'>
							<h3
								class={`text-base font-semibold mb-2 text-${expertise.color} group-hover:opacity-100 transition-opacity`}
							>
								{expertise.area}
							</h3>
							<p class='text-gray-500 text-sm mb-5 leading-relaxed'>
								{expertise.description}
							</p>
							<div class='flex flex-wrap gap-2 mt-auto'>
								{expertise.tools.map((tool) => (
									<span class='px-1 py-1 text-xs font-mono bg-white/5 text-gray-500 rounded'>
										{tool}
									</span>
								))}
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<Footer />
</BaseLayout>
