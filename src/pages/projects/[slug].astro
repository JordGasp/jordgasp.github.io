---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={`${project.data.title} - Jordan Gaspoz`} description={project.data.description}>
  <!-- Back button -->
  <div class="max-w-7xl mx-auto px-4 pt-8">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-gray-400 hover:text-accent-green transition-colors duration-300 mb-8"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <span>Back to projects</span>
    </a>
  </div>

  <!-- Project Header -->
  <header class="max-w-5xl mx-auto px-4 py-12">
    <h1
      class="text-4xl md:text-5xl font-bold mb-4 pb-2 bg-gradient-to-r from-accent-green to-accent-purple bg-clip-text text-transparent brightness-100 contrast-100"
      style="color: transparent; -webkit-background-clip: text;"
    >
      {project.data.title}
    </h1>
    <p class="text-xl text-accent-purple font-mono mb-6">
      {project.data.tagline}
    </p>
    <p class="text-lg text-gray-400 mb-8">
      {project.data.description}
    </p>

    <!-- Tech Stack -->
    <div class="flex flex-wrap gap-2 mb-6">
      {project.data.tech.map((tech) => (
        <span class="px-4 py-2 text-sm font-mono bg-dark-card border border-dark-border rounded-full text-gray-400 hover:border-accent-green/50 transition-colors duration-300">
          {tech}
        </span>
      ))}
    </div>

    <!-- GitHub Link -->
    {project.data.github && (
      <a
        href={project.data.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-dark-card border border-dark-border hover:border-accent-green text-dark-text font-semibold rounded-lg transition-all duration-300 hover:scale-105"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
        </svg>
        <span>View on GitHub</span>
      </a>
    )}
  </header>

  <article class="max-w-7xl mx-auto px-6 py-12 prose prose-invert prose-lg">
    <Content />
  </article>

  <Footer />
</BaseLayout>

<style is:global>
  /* Prose styling for markdown content */
  .prose {
    color: #e5e5e5;
  }

  .prose h2 {
    color: #10b981;
    font-size: 2rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #2a2a2a;
    padding-bottom: 0.5rem;
  }

  .prose h3 {
    color: #8b5cf6;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose h4 {
    color: #e5e5e5;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose p {
    color: #9ca3af;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .prose ul, .prose ol {
    color: #9ca3af;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose strong {
    color: #e5e5e5;
    font-weight: 600;
  }

  .prose code {
    background-color: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    color: #10b981;
  }

  .prose pre {
    background-color: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 0.5rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose pre code {
    background-color: transparent;
    border: none;
    padding: 0;
    color: #e5e5e5;
  }

  .prose a {
    color: #10b981;
    text-decoration: none;
    transition: color 0.3s;
  }

  .prose a:hover {
    color: #8b5cf6;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .prose th {
    background-color: #1a1a1a;
    border: 1px solid #2a2a2a;
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    color: #10b981;
  }

  .prose td {
    border: 1px solid #2a2a2a;
    padding: 0.75rem;
    color: #9ca3af;
  }

  .prose hr {
    border: none;
    border-top: 1px solid #2a2a2a;
    margin: 3rem 0;
  }

  .prose blockquote {
    border-left: 4px solid #10b981;
    padding-left: 1.5rem;
    font-style: italic;
    color: #9ca3af;
    margin: 1.5rem 0;
  }

  /* Image styling */
  .prose img {
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid #2a2a2a;
    margin: 2rem auto;
    display: block;
  }

  /* Default size for images without width attribute */
  .prose img:not([width]) {
    max-width: 800px;
    width: 100%;
  }
</style>
